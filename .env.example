# Frontend (Next.js) — /var/www/instrument
PORT=3011
HOSTNAME=127.0.0.1
NEXT_PUBLIC_BASE_PATH=/instrument
BASE_PATH=/instrument
# Browser calls this path; Apache proxies to API :8011
NEXT_PUBLIC_API_URL=/instrument/api

# Admin — must match ADMIN_PASSWORD in .env.api (API write guards)
ADMIN_PASSWORD=psimkg-admin
# Optional shared session cookie value (Next middleware + API)
# ADMIN_SESSION_SECRET=psimkg-session-active
